% ======================================
% Listings Style
% ======================================

\lstdefinestyle{notepadstyle}{
  language=Python,
  backgroundcolor=\color{editorbg},
  basicstyle=\ttfamily\small\color{editortext},
  tabsize=2,
  keywordstyle=\bfseries\color{keywordcolor},
  commentstyle=\itshape\color{commentcolor},
  numberstyle=\tiny\color{numbercolor},
  stringstyle=\color{stringcolor},
  numbers=left,
  numberstyle=\footnotesize\ttfamily\color{guttertext},
  numbersep=10pt,
  xleftmargin=24pt,
  showstringspaces=false,
  keepspaces=true,
  breaklines=true,
  columns=fullflexible,
  frame=none,
  aboveskip=0pt,
  belowskip=0pt
}

% ======================================
% Code Box
% ======================================

\newtcblisting{codingbox}[1][]{
  enhanced,
  breakable,
  colback=editorbg,
  colframe=outerborder,
  boxrule=1pt,
  left=0pt,
  right=6pt,
  top=6pt,
  bottom=6pt,
  underlay={
      \fill[gutterbg]
      (frame.north west)
      rectangle
      ([xshift=24pt]frame.south west);
    },
  overlay={
      % Vertical separator
      \draw[outerborder, line width=0.5pt]
      ([xshift=24pt]frame.north west) --
      ([xshift=24pt]frame.south west);
    },
  listing only,
  listing engine=listings,
  listing options={
      style=notepadstyle,
      #1
    }
}

